#!/usr/bin/env bash
set -euo pipefail

# refresh-getlamina — update getlamina.ai with current versions and deps
#
# Usage: bin/refresh-getlamina [--deploy]
#
# Updates catalog.yaml with current versions and deps from the workspace,
# then rebuilds index.html via `go run ./cmd/render`. With --deploy,
# copies to hestia and deploys to Cloudflare Pages.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SITE_DIR="${GETLAMINA_DIR:-/Users/benaskins/dev/tegmen/getlamina.ai}"
CATALOG="$SITE_DIR/catalog.yaml"
DEPLOY=false

if [[ "${1:-}" == "--deploy" ]]; then
  DEPLOY=true
fi

if [[ ! -f "$CATALOG" ]]; then
  echo "ERROR: catalog not found: $CATALOG" >&2
  exit 1
fi

echo "==> Updating versions in catalog.yaml"

for dir in "$ROOT"/*/ "$ROOT"/apps/*/; do
  [[ -d "$dir" ]] || continue
  name="$(basename "$dir")"
  [[ -d "$dir/.git" ]] || continue

  tag=$(cd "$dir" && git describe --tags --abbrev=0 2>/dev/null || echo "")
  [[ -z "$tag" ]] && continue

  # Update version lines: match "id: <name>" then update the next "version:" line
  if grep -q "id: $name" "$CATALOG" 2>/dev/null; then
    # Use awk to find "id: <name>" and update the following "version:" line
    awk -v id="$name" -v ver="$tag" '
      /^[[:space:]]*id:/ && $2 == id { found=1 }
      found && /^[[:space:]]*version:/ { sub(/version:.*/, "version: " ver); found=0 }
      { print }
    ' "$CATALOG" > "${CATALOG}.tmp"
    mv "${CATALOG}.tmp" "$CATALOG"
    echo "  $name → $tag"
  fi
done

echo "==> Updating deps in catalog.yaml"

# Build new deps block from go.mod files
deps_block="deps:"
for dir in "$ROOT"/*/ "$ROOT"/apps/*/; do
  [[ -d "$dir" ]] || continue
  name="$(basename "$dir")"
  modfile="$dir/go.mod"
  [[ -f "$modfile" ]] || continue

  deps=$( (grep 'github.com/benaskins/' "$modfile" || true) \
    | (grep -v '^module' || true) \
    | sed 's|.*github.com/benaskins/||; s| .*||' \
    | (grep -v "^${name}$" || true) \
    | sort -u )

  [[ -z "$deps" ]] && continue

  dep_list=$(echo "$deps" | paste -sd, - | sed 's/,/, /g')
  deps_block+=$'\n'"  $name: [$dep_list]"
done

# Replace deps block (everything from "deps:" to end of file)
deps_line=$(grep -n '^deps:' "$CATALOG" | head -1 | cut -d: -f1)
if [[ -n "$deps_line" ]]; then
  head -n "$((deps_line - 1))" "$CATALOG" > "${CATALOG}.tmp"
  echo "$deps_block" >> "${CATALOG}.tmp"
  mv "${CATALOG}.tmp" "$CATALOG"
  echo "  deps updated"
fi

echo "==> Building index.html"
(cd "$SITE_DIR" && go run ./cmd/render)

echo "==> Done"

if $DEPLOY; then
  echo "==> Deploying to hestia + Cloudflare"
  scp "$SITE_DIR/index.html" "$CATALOG" hestia:~/dev/sites/getlamina.ai/
  ssh hestia 'source ~/.zshrc 2>/dev/null; cd ~/dev/sites && bin/deploy-site getlamina.ai'
fi
